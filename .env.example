POSTGRES_USER=lexcore
POSTGRES_PASSWORD=lexcore
POSTGRES_DB=lexcore

# Cambiar por un valor seguro en prod (openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-prod

ENVIRONMENT=development

NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth — crear en https://console.cloud.google.com/apis/credentials?project=lexcore-app
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# NextAuth — generar con: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=xxxx
NEXTAUTH_URL=http://localhost:3001

# Email via Resend — https://resend.com/api-keys
# Dejar vacío en dev: los emails se omiten silenciosamente
RESEND_API_KEY=
BASE_URL=http://localhost:3001

# MercadoPago — https://www.mercadopago.com.ar/developers/panel/credentials
# TEST: usar credenciales de sandbox para desarrollo
# PROD: reemplazar por credenciales de producción en Railway
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx   # Secret Key (backend only)
MERCADOPAGO_PUBLIC_KEY=TEST-xxxx     # Public Key (frontend, exponer como NEXT_PUBLIC_MP_PUBLIC_KEY)
MERCADOPAGO_WEBHOOK_SECRET=          # Firma para validar notificaciones IPN de MP

# Storage de documentos
# Dev local: MinIO corre en docker-compose, ya configurado automáticamente
# S3_ENDPOINT_URL=http://minio:9000  ← ya está en docker-compose.yml
#
# Prod (Cloudflare R2): dejar S3_ENDPOINT_URL vacío y completar:
# S3_ENDPOINT_URL=
# R2_ACCOUNT_ID=tu-account-id
# R2_ACCESS_KEY_ID=tu-access-key
# R2_SECRET_ACCESS_KEY=tu-secret-key
# R2_BUCKET_NAME=lexcore-docs

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX  # GA4 Measurement ID (opcional — sin esta var no carga GA)
