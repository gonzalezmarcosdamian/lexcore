{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "dockerContextPath": "backend",
    "dockerBuildTarget": "prod"
  },
  "deploy": {
    "startCommand": "/entrypoint.sh",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
